# PostgreSQL (Supabase: Project Settings → Database → URI; paste password from dashboard)
# App/runtime: pooler URL (port 6543) with query params Prisma recommends, e.g.
#   ?pgbouncer=true&connection_limit=1
# CLI (prisma db push / migrate): direct connection (port 5432) — same host, non-pooler.
# Never commit real credentials; copy .env.example to .env locally.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# College Scorecard (https://api.data.gov/signup/) — used by npm run scorecard:import
SCORECARD_API_KEY=

# Anthropic (https://console.anthropic.com/) — server-side only; school AI summaries
ANTHROPIC_API_KEY=
# Optional; defaults to claude-sonnet-4-6. See https://docs.anthropic.com/en/docs/about-claude/models/overview
ANTHROPIC_MODEL=

# Google OAuth (https://console.cloud.google.com/) — Gmail integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth — session encryption; generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# SwimCloud (local Playwright only — see scripts/swimcloud/README.md)
# When Cloudflare loops: npm run swimcloud:chrome-debug, then npm run swimcloud:auth:cdp
# SWIMCLOUD_CDP_URL=http://127.0.0.1:9222
# SWIMCLOUD_CDP_PORT=9222
# CHROME_PATH=/path/to/Google Chrome
# Session: run `npm run swimcloud:auth` once; do not put SwimCloud passwords in .env long-term.
# SWIMCLOUD_EMAIL= / SWIMCLOUD_PASSWORD= only if you add a non-interactive login script.
# SWIMCLOUD_STORAGE_STATE=.local/swimcloud-storage.json
# SWIMCLOUD_BROWSER_PROFILE=.local/swimcloud-browser-profile
# SWIMCLOUD_SMOKE_URL=https://www.swimcloud.com/team/261/how-do-i-fit/
# SWIMCLOUD_SMOKE_WAIT_MS=45000
# SWIMCLOUD_TARGETS=data/swimcloud-targets.json
# SWIMCLOUD_FETCH_DELAY_MS=3000
# SWIMCLOUD_FETCH_HEADED=1
# SWIMCLOUD_TARGETS_SOURCE=db
# SWIMCLOUD_SCORECARD_MAP=data/swimcloud-scorecard-map.json
# SWIMCLOUD_HEADED=1
# SWIMCLOUD_PLAYWRIGHT_CHANNEL=chromium
