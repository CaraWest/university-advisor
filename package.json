{
  "name": "university-advisor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "npx prisma generate",
    "env:ensure": "node scripts/ensure-env.mjs",
    "db:backup": "node scripts/db-backup.mjs",
    "predev": "npm run env:ensure && npm run db:backup && npx prisma db push && npx tsx prisma/dev-prep.ts",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "scorecard:import": "tsx scripts/scorecard-import.ts",
    "email-domains:populate": "tsx scripts/populate-email-domains.ts",
    "enrich:all": "tsx scripts/enrich-all.ts",
    "db:restore": "node scripts/db-restore.mjs",
    "db:restore-from-sqlite": "tsx scripts/restore-sqlite-to-postgres.ts",
    "swimcloud:auth": "tsx scripts/swimcloud/auth.ts",
    "swimcloud:chrome-debug": "tsx scripts/swimcloud/open-chrome-debug.ts",
    "swimcloud:auth:cdp": "tsx scripts/swimcloud/auth-cdp.ts",
    "swimcloud:smoke": "tsx scripts/swimcloud/smoke.ts",
    "swimcloud:fetch": "tsx scripts/swimcloud/fetch.ts",
    "swimcloud:fetch:headed": "SWIMCLOUD_FETCH_HEADED=1 tsx scripts/swimcloud/fetch.ts",
    "swimcloud:fetch:db": "SWIMCLOUD_TARGETS_SOURCE=db tsx scripts/swimcloud/fetch.ts",
    "swimcloud:map:sync": "tsx scripts/sync-swimcloud-scorecard-map.ts",
    "swimcloud:backfill:team-ids": "tsx scripts/backfill-swimcloud-team-ids.ts",
    "swimcloud:validate": "tsx scripts/swimcloud/validate-sample.ts",
    "import:run": "tsx scripts/run-import-pipeline.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.20.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "googleapis": "^171.4.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.460.0",
    "next": "14.2.18",
    "next-auth": "^4.24.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "playwright": "^1.59.1",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "env CONFIRM_RESEED=true tsx prisma/seed.ts"
  }
}
