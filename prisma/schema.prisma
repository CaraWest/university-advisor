generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id               String    @id @default(cuid())
  name             String
  state            String
  city             String?
  scorecardId      Int? // College Scorecard API institution id
  institutionType  String
  latitude         Float?
  longitude        Float?
  distanceFromHome Float?

  status          String  @default("None") @map("lifecycleStatus")
  rejectionReason String?

  abigailFavorite    Boolean @default(false)
  interested         Boolean @default(false)
  phoneCall          Boolean @default(false)
  campusVisit        Boolean @default(false)
  enrichmentComplete Boolean @default(false)

  notes String?

  aiSummary          String?
  summaryGeneratedAt DateTime?

  appDeadlineEA DateTime?
  appDeadlineED DateTime?
  appDeadlineRD DateTime?

  swimData        SwimData?
  academicProfile AcademicProfile?
  financialModel  FinancialModel?
  coachContacts   CoachContact[]
  emailDomains    SchoolEmailDomain[]
  gmailLinks      GmailSchoolLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([state])
  @@index([scorecardId])
}

model SwimData {
  id                String   @id @default(cuid())
  schoolId          String   @unique
  school            School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  ncaaDivision      String?
  hasSwimTeam       Boolean  @default(true)
  notInSwimCloud    Boolean  @default(false)
  athleticTier      String?
  teamPowerIndexAvg Float?
  abigailRank       Int?
  rosterSize        Int?
  seniorsGraduating Int?
  swimcloudUrl      String?
  /// Curated: SwimCloud /team/{id}/ — from map sync or import scrapeTeamId.
  swimcloudTeamId   Int?
  dataCollectedAt   DateTime?

  // SwimCloud page extras; scorecard still wins on shared AcademicProfile fields.
  matchScore        Int?
  teamRankDisplay   String?
  conference        String?
  athleteEvent      String?
  distanceMiles     Int?
  schoolSize        String?
  pageCity          String?
  pageState         String?
  pageSetting       String?
  // Observed net cost on SwimCloud page; FinancialModel.estimatedNetCost when that slot is empty.
  swimcloudAvgNetCost Int?
  // Full validated school row JSON for keys not mapped to columns.
  importSnapshotJson  String?
  // Enrichment (Claude web_search): swimming/diving coaching staff from official athletics site; JSON array of { name, title?, email?, phone?, profileUrl? }.
  coachingStaffJson   String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([swimcloudTeamId])
}

model AcademicProfile {
  id                  String   @id @default(cuid())
  schoolId            String   @unique
  school              School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  programLabel        String?
  programType         String?
  flagshipSchool      String?
  programNotes        String?
  studyAbroadLevel    String?
  studyAbroadNotes    String?
  acceptanceRate      Float?
  satMid50Low         Int?
  satMid50High        Int?
  satMathMid50Low     Int?
  satMathMid50High    Int?
  satEBRWMid50Low     Int?
  satEBRWMid50High    Int?
  enrollmentSize      Int?
  setting             String?
  retentionRate       Float?
  gradRate4Year       Float?
  studentFacultyRatio Float?
  t14Placements       String?
  preLawQuality       String?
  feederReputation    String?
  dataCollectedAt     DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model FinancialModel {
  id                   String   @id @default(cuid())
  schoolId             String   @unique
  school               School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  publishedCOA         Int?
  averageAnnualCost    Int? // College Scorecard latest.cost.avg_net_price.overall (AAC / avg net price)
  tuition              Int?
  roomAndBoard         Int?
  feesAndOther         Int?
  estimatedMeritAid    Int?
  athleticAidAvailable Boolean?
  estimatedAthleticAid Int?
  needAidLikely        Boolean?
  avgNetCostHighIncome Int?
  estimatedNetCost     Int?
  fourYearEstimate     Int?
  financialNotes       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model CoachContact {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  date         DateTime
  direction    String
  type         String
  summary      String
  rawContent   String? // JSON text; optional future migration to Prisma Json
  draftedReply Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([schoolId])
}

model SchoolEmailDomain {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  domain    String   @unique
  createdAt DateTime @default(now())

  @@index([schoolId])
}

model GmailSchoolLink {
  id             String   @id @default(cuid())
  schoolId       String
  school         School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  gmailMessageId String   @unique
  senderEmail    String
  subject        String?
  linkedAt       DateTime @default(now())

  @@index([schoolId])
}

model StudentProfile {
  id                  String   @id @default(cuid())
  powerIndex          Float?
  satMath             Int?
  satEBRW             Int?
  satComposite        Int?
  gpa                 Float?
  graduationYear      Int?
  studyAbroadInterest Boolean  @default(true)
  divisionPreference  String?
  sizePreference      String?
  geographyNotes      String?
  writingProfile      String?
  studyAbroadProfile  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}